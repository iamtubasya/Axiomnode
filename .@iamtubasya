/* ================= JAM ================= */
function now(){
    return "[" . date("H:i:s") . "]";
}


function convertjam($detik) {
    $jam = floor($detik / 3600); 
    $detik %= 3600;
    $menit = floor($detik / 60);
    $detik %= 60;

    return sprintf("%02dH %02dM %02dS", $jam, $menit, $detik);
}



/* ================= LOAD PROXY ================= */
function loadProxies(){
    global $proxyFile, $proxyQueue;

    // jika file tidak ada -> mode tanpa proxy
    if(!file_exists($proxyFile)){
        $proxyQueue = [];
        return;
    }

    $lines = file($proxyFile, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
    $proxyQueue = array_values(array_filter(array_map('trim', $lines)));

    if(empty($proxyQueue)){
        $proxyQueue = [];
        return;
    }
}

